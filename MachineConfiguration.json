[{
    "TargetMachineNames": ["Server01SA", "Server01SAB", "SLAPPY"],
    "TimeZone": "AUS Eastern Standard Time",
    "IISServerAdvancedSettings": [
        {
            "system.web/machineKey/validation": "HMACSHA256",
            "system.web/machineKey/decryption": "AES",
            "system.web/machineKey/validationKey": "#{SubstGlobalMachineKeyValidationKey}#",
            "system.web/machineKey/decryptionKey": "#{SubstGlobalMachineKeyDecryptionKey}#"
        }
    ],
    "IISAppPools": [
        {
            "Name": "Pool1",
            "ManagedRuntimeVersion": "v4.0",
            "ManagedPipelineMode": "Integrated",
            "AdvancedSettings": {
                "StartMode": "AlwaysRunning"
            }
        },
        {
            "Name": "Pool2",
            "ManagedRuntimeVersion": "v4.0",
            "ManagedPipelineMode": "Classic",
            "AdvancedSettings": {
                "StartMode": "AlwaysRunning",
                "QueueLength": 3123,
                "ProcessModel.idleTimeout": "00:25:00",
                "recycling.periodicRestart.schedule": [
                    { "value": "02:00:00" },
                    { "value": "15:00:00" }
                ]
            }
        }
    ],
    "IISWebSites": [{
        "SiteName": "Site1",
        "ContentPath": "c:\\inetpub\\content\\site1",
        "AppPool": "Pool1",
        "Bindings": [
            {
                "Protocol": "http",
                "Port": 80,
                "HostHeader": "site1.local"
            }
        ],
        "FailedRequestTracing":
        {
          "Enabled": true,
          "LogDirectory": "E:\\inetpub\\logs\\FailedReqLogFiles\\extranet",
          "MaxTraceFiles": 50
        },
        "AdvancedSettings": [
            {
                "PhysicalPathCredential": {

                },
                "PhysicalPathCredentialsLogon": "ClearText",
                "PreloadEnabled": true,
                "logFile.logFormat": "IIS",
                "logFile.directory": "E:\\inetpub\\logs\\logfiles\\extranet",
                "system.webServer/security/authentication/anonymousAuthentication.enabled": true,
                "system.webServer/security/authentication/anonymousAuthentication.userName": "",
                "system.webServer/security/authentication/windowsAuthentication.enabled": false,
                "system.web/machineKey/validation": "SHA1",
                "system.web/machineKey/decryption": "Auto",
                "system.web/machineKey/validationKey": "#{SubstMachineKeyValidationKey}#",
                "system.web/machineKey/decryptionKey": "#{SubstMachineKeyDecryptionKey}#"
            }
        ],
        "WebApps": [
            {
                "Name": "Site1",
                "ContentPath": "c:\\inetpub\\content\\site1\\webapp1",
                "AppPool": "Pool2",
                "Bindings": [
                    {
                        "Protocol": "http",
                        "Port": 80,
                        "HostHeader": "site1.local"
                    }
                ],
                "AdvancedSettings": [
                    {
                        "PhysicalPathCredential": {

                        },
                        "PhysicalPathCredentialsLogon": "ClearText",
                        "PreloadEnabled": true
                    }
                ]
            }
        ]
    },
    {
        "SiteName": "Site2-AppPoolIdentityAuth",
        "ContentPath": "c:\\inetpub\\content\\site2",
        "AppPool": "Pool1",
        "Bindings": [
            {
                "Protocol": "http",
                "Port": 80,
                "HostHeader": "site2.local"
            }
        ],
        "AdvancedSettings": [
            {
                "system.webServer/security/authentication/anonymousAuthentication.enabled": true,
                "system.webServer/security/authentication/anonymousAuthentication.userName": "",
                "system.webServer/security/authentication/windowsAuthentication.enabled": false
            }
        ]
    },
    {
        "SiteName": "Site3-SpecificUserAuth",
        "ContentPath": "c:\\inetpub\\content\\site3",
        "AppPool": "Pool2",
        "Bindings": [
            {
                "Protocol": "http",
                "Port": 80,
                "HostHeader": "site3.local"
            }
        ],
        "AdvancedSettings": [
            {
                "system.webServer/security/authentication/anonymousAuthentication.enabled": true,
                "system.webServer/security/authentication/anonymousAuthentication.userName": "Domain\\SpecificUser",
                "system.webServer/security/authentication/anonymousAuthentication.password": "SuperSecret123!",
                "system.webServer/security/authentication/windowsAuthentication.enabled": false
            }
        ]
    }],
    "Directories": [
        {
            "Path": "c:\\BusinessObjects",
            "Attributes": {
                "ReadOnly": false,
                "Hidden": false,
                "System": false
            },
            "Permissions": [
                {
                    "AccountName": "Domain\\OldUser",
                    "Ensure": "Absent"
                },
                {
                    "AccountName": "Administrators",
                    "Access": "FullControl",
                    "Ensure": "Present"
                }
            ],
            "Shares": [
                {
                    "Name": "BusinessObjects-Share",
                    "Type": "Folder",
                    "Description": "Share-BusinessObjects",
                    "AdministrativeShare": false,
                    "Permissions": [
                        {
                            "AccountName": "Domain\\OldUser",
                            "Ensure": "Absent"
                        },
                        {
                            "AccountName": "Domain\\Administrator",
                            "Access": "FullControl",
                            "Ensure": "Present"
                        }
                    ]
                }
            ]
        }
    ],
    "Hosts": [
        {
            "HostName": "old.site1.local",
            "Ensure": "Absent"
        },
        {
            "HostName": "site1.local",
            "IpAddress": "127.0.0.1",
            "Ensure": "Present"
        },
        {
            "HostName": "dummy.site1.local",
            "IpAddress": "127.0.0.1",
            "Ensure": "Present"
        }
    ],
    "EnabledFeatures": [
    ],
    "DisabledFeatures": [
    ],
    "Certificates": [
        {
            "Name": "SomeOldCert",
            "Thumbprint": "#{AbsentCertThumbprint_SomeOldCert}#",
            "Ensure": "Absent",
            "ManageForAccount": "Computer"
        },
        {
            "SecureFile": "TheApp_Dev.pfx",
            "PasswordKey": "TheApp_Dev",
            "ManageForAccount": "Computer",
            "ReadAccessAccounts": [
                "#{SvcAccountDomain}#\\#{SvcAccountName}#"
            ],
            "Ensure": "Present"
        }
    ],
    "EventLogs": {
        "MyCustomAppSource": {
            "LogName": "SteveTestLog",
            "EventId": 3000,
            "Level": "Information"
        }
    }

}]
